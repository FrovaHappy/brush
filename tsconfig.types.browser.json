{
  "extends": "./tsconfig.browser.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "isolatedModules": false,
    "module": "esnext",
    "emitDeclarationOnly": true,
    "outDir": "./dist/types"
  },
  "include": [
    "src/browser.ts",
    "src/types.d.ts",
    "src/core/**/*",
    "src/platforms/**/*"
  ]
}
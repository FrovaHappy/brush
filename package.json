{
  "name": "@frova_happy/brush",
  "version": "0.2.0",
  "description": "Una librería de canvas universal que funciona tanto en el navegador como en Node.js",
  "type": "module",
  "exports": {
    "./browser": {
      "types": "./dist/types/browser.d.ts",
      "import": "./dist/browser/index.js"
    },
    "./node": {
      "types": "./dist/types/node.d.ts",
      "import": "./dist/node/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:js": "node build.mjs",
    "build:types": "tsc -p tsconfig.types.node.json && tsc -p tsconfig.types.browser.json",
    "build": "npm run clean && npm run build:js && npm run build:types",
    "clean": "rimraf dist",
    "lint": "biome lint",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "canvas",
    "drawing",
    "graphics",
    "universal",
    "node",
    "browser",
    "2d"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@napi-rs/canvas": "0.1.88",
    "colorthief": "3.3.1",
    "node-vibrant": "4.0.4",
    "sharp": "0.35.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@types/node": "25.9.3",
    "esbuild": "0.27.2",
    "rimraf": "6.1.2",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  },
  "peerDependenciesMeta": {},
  "engines": {
    "node": ">=20.0.0"
  }
}
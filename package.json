{
  "name": "@frova_happy/brush",
  "version": "0.2.0",
  "description": "Una librería de canvas universal que funciona tanto en el navegador como en Node.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/node.d.ts",
      "import": "./dist/node/index.js"
    },
    "./web": {
      "types": "./dist/types/web.d.ts",
      "import": "./dist/web/index.js"
    },
    "./node": {
      "types": "./dist/types/node.d.ts",
      "import": "./dist/node/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:js && npm run build:types",
    "build:js": "node build.mjs",
    "build:types": "tsc -p tsconfig.types.json",
    "clean": "rimraf dist",
    "dev:html": "npm run build && npx http-server@14.1.1 . -p 3000 -o /example/html/index.html",
    "dev:react": "npm run build && cd example/react && npm install && npm run dev",
    "dev:node": "npm run build && cd example/node && npm install && npm run start",
    "lint": "biome lint",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "canvas",
    "drawing",
    "graphics",
    "universal",
    "node",
    "browser",
    "2d"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@napi-rs/canvas": "0.1.88",
    "node-vibrant": "4.0.4",
    "vitest": "4.0.16",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@types/node": "25.9.3",
    "esbuild": "0.27.2",
    "rimraf": "6.1.2",
    "typescript": "5.9.3"
  },
  "peerDependenciesMeta": {},
  "engines": {
    "node": ">=16.0.0"
  }
}
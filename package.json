{
  "name": "@frova_happy/brush",
  "version": "0.4.1",
  "description": "Una librería de canvas universal que funciona tanto en el navegador como en Node.js",
  "type": "module",
  "exports": {
    "./browser": {
      "types": "./dist/types/browser.d.ts",
      "import": "./dist/browser/index.js"
    },
    "./node": {
      "types": "./dist/types/node.d.ts",
      "import": "./dist/node/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README-Spanish.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build:js": "node build.mjs",
    "build:types": "tsc -p tsconfig.types.node.json && tsc -p tsconfig.types.browser.json",
    "build": "pnpm run clean && pnpm run build:js && pnpm run build:types",
    "lint": "biome lint",
    "test": "vitest",
    "build:publish": "pnpm run build && npm link",
    "dev:node": "pnpm run build:publish && cd example/node && pnpm install && node index.js",
    "dev:html": "cd example/html && pnpx -y serve -l 3000",
    "dev:react": "pnpm run build:publish && cd example/react && pnpm install && pnpm run dev",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "canvas",
    "drawing",
    "graphics",
    "universal",
    "node",
    "browser",
    "2d"
  ],
  "author": "FrovaHappy",
  "license": "MIT",
  "dependencies": {
    "@napi-rs/canvas": "1.0.2",
    "colorthief": "3.3.1",
    "sharp": "0.35.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "26.0.1",
    "esbuild": "0.28.1",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "peerDependenciesMeta": {},
  "engines": {
    "node": ">=24.0.0"
  }
}